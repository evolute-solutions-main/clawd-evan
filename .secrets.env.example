# Secrets for local/dev + gateway cron jobs
# Copy to .secrets.env and fill in values. Do NOT commit.

# Asana
ASANA_PAT=

# Discord (only if you ever run a custom bot integration; Clawdbot itself stores its Discord auth separately)
# DISCORD_BOT_TOKEN=

# OpenAI (only if you use API-key based models/tools outside Codex OAuth)
# OPENAI_API_KEY=

# Anthropic (only if you use API-key based access)
# ANTHROPIC_API_KEY=
